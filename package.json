{
  "name": "goout-hyd",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run web",
    "web": "npm run dev --workspace=web",
    "web:build": "npm run build --workspace=web",
    "web:start": "npm run start --workspace=web",
    "build": "npm run build --workspace=web",
    "start": "npm run start --workspace=web",
    "type-check": "npm run type-check --workspace=web",
    "db:generate": "npm run db:generate --workspace=web",
    "db:generate:prod": "npm run db:generate:prod --workspace=web",
    "db:generate:custom": "npm run db:generate:custom --workspace=web",
    "db:generate:custom:prod": "npm run db:generate:custom:prod --workspace=web",
    "db:migrate": "npm run db:migrate --workspace=web",
    "db:migrate:prod": "npm run db:migrate:prod --workspace=web",
    "db:rollback": "npm run db:rollback --workspace=web",
    "db:rollback:prod": "npm run db:rollback:prod --workspace=web",
    "db:status": "npm run db:status --workspace=web",
    "db:status:prod": "npm run db:status:prod --workspace=web",
    "db:seed": "npm run db:seed --workspace=web",
    "db:studio": "npm run db:studio --workspace=web",
    "setup": "npm install --workspace=web",
    "env:pull:dev": "cd apps/web && npm run env:pull:dev",
    "env:pull:prod": "cd apps/web && npm run env:pull:prod",
    "lint": "npm run lint --workspaces",
    "format": "prettier --write .",
    "clean": "npm run clean --workspaces --if-present"
  },
  "overrides": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "eslint": "^9",
    "typescript": "^5",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3"
  }
}
