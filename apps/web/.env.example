# Copy to `.env.local` and fill in real values (never commit `.env.local`).

DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional — partner lead notification email via Resend
# RESEND_API_KEY=
# LEAD_NOTIFICATION_EMAIL=

# Optional — Razorpay ticketing
# NEXT_PUBLIC_RAZORPAY_KEY_ID=
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# --- On-demand revalidation (task 016) + Phase 1 ops (task 019) ---
# Set these on Vercel → Project → Settings → Environment Variables → Production,
# then redeploy once so values bind and cache can refresh.
#
# REVALIDATE_SECRET — shared with POST /api/revalidate (min 32 chars when set).
# Generate: openssl rand -hex 32   OR   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REVALIDATE_SECRET=
#
# REVALIDATE_BASE_URL — canonical production origin whose cache to purge (https).
# REVALIDATE_BASE_URL=https://www.goouthyd.com

# --- Admin password session (task 019 — required in `lib/env.ts`; match Vercel Production) ---
# ADMIN_PASSWORD — min 12 chars. Shared login for /admin (share only with operators).
# ADMIN_COOKIE_SECRET — min 32 chars (CSPRNG). Signs the admin session JWT cookie.
# openssl rand -hex 32   OR   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_PASSWORD=
ADMIN_COOKIE_SECRET=
