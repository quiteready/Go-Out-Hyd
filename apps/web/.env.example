# Copy to `.env.local` and fill in real values (never commit `.env.local`).

DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional — partner lead notification email via Resend
# RESEND_API_KEY=
# LEAD_NOTIFICATION_EMAIL=

# Optional — Razorpay ticketing
# NEXT_PUBLIC_RAZORPAY_KEY_ID=
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# On-demand revalidation (task 016): purge production Next.js cache when using
# localhost admin against a production database. Set the same REVALIDATE_SECRET
# on Vercel (production) and locally; set REVALIDATE_BASE_URL only on the machine
# that triggers purges (usually local = production site origin).
# Generate secret: openssl rand -hex 32
# REVALIDATE_SECRET=
# REVALIDATE_BASE_URL=https://www.goouthyd.com
